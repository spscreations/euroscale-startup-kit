FROM golang:1.26-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /mysql-proxy ./cmd/mysql-proxy

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=builder /mysql-proxy /mysql-proxy
EXPOSE 3307
ENTRYPOINT ["/mysql-proxy"]
